# .env.example
# Copy to .env for local development. NEVER commit .env.
# For production Pi deployment, set these as systemd EnvironmentFile entries.

# === REQUIRED — must be set before any binary will start ===

# HMAC secret shared between desktop app and Pi controller.
# Generate: openssl rand -hex 32
MANPADS_HMAC_SECRET=

# Operator session token validated on every command.
# Generate: openssl rand -hex 16
MANPADS_OPERATOR_TOKEN=

# === OPTIONAL — have sensible defaults ===

# Pi controller bind address (Pi side)
MANPADS_LISTEN_ADDR=127.0.0.1:8080

# Desktop app UDP listener address
MANPADS_DESKTOP_ADDR=127.0.0.1:8081

# Watchdog disarm timeout in milliseconds (default: 1500)
MANPADS_WATCHDOG_MS=1500

# Telemetry broadcast interval in milliseconds (default: 100 = 10Hz)
MANPADS_TELEMETRY_INTERVAL_MS=100

# Log level (default: info)
RUST_LOG=pi_controller=info,warn
